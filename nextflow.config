docker.enabled = true

params {
    help           = false
    input_dir      = './tests/data'
    reads_pattern  = "*_R{1,2}_001_redu.fastq.gz"
    output_dir     = './tests/output_nf'
    full_output    = true
    method         = 'both'   // dada2 | vsearch | both
    skip_tax_annot = false
    nslots         = 12
    maxForks       = 3
    
    // Tag of the ghcr.io/pereiramemo/amp-proc/* images to pull, applied to every
    // module (see modules/*.nf). Defaults to the moving "latest"; pin to a published
    // version for reproducible runs (--container_tag v1.0.0, or set it here).
    container_tag  = "latest"

    // Primers (shared by MODULE_1_2_PRIMERS_CHECK and MODULE_1_3_PRIMERS_REMOVAL)
    primer_fwd = "GTGYCAGCMGCCGCGGTAA"
    primer_rev = "CCGYCAATTYMTTTRAGTTT"

    // MODULE_1_1_QUALITY_CHECK — quality check
    // no parameters needed for this module

    // MODULE_1_2_PRIMERS_CHECK — primer check (before / after)
    subsample_size = 1000

    // MODULE_1_3_PRIMERS_REMOVAL — cutadapt primer removal
    error_rate        = 0.1
    min_overlap       = 5
    min_length        = 50
    discard_untrimmed = 't'

    // MODULE_2_1_DADA2_PIPELINE — DADA2 (ASV)
    trunc_r1          = 250
    trunc_r2          = 200
    dada2_min_overlap = 12
    bimeras_method    = 'consensus'

    // MODULE_2_2_1_VSEARCH_PIPELINE — VSEARCH per-sample
    fastq_minovlen     = 5
    fastq_maxdiffs     = 2
    fastq_maxee        = 1.0
    min_size           = 1
    abskew             = 2.0
    vsearch_min_length = 50

    // MODULE_2_2_2_VSEARCH_PIPELINE — VSEARCH OTU construction
    identity = 0.97

    // MODULE_3_TAXA_ANNOT — taxonomic annotation
    taxa_method = "NBC"
    train_db    = "${System.getenv('HOME')}/.amp-proc/db/silva_nr99_v138.2_toGenus_trainset.fa.gz"
    ref_db      = "${System.getenv('HOME')}/.amp-proc/db/silva_v138.2_assignSpecies.fa.gz"
}

// Total CPU budget for the local executor. Nextflow will not start a task whose
// `cpus` request cannot be met from this budget, which is what lets a full-budget
// module (DADA2 / VSEARCH OTU) run on its own with every thread. Assumes
// nslots * maxForks does not exceed the machine's physical cores.
executor {
    cpus = params.nslots * params.maxForks
}

process {
    // Per-sample modules reserve `nslots` CPUs each, so up to `maxForks` run at once.
    cpus     = params.nslots
    maxForks = params.maxForks

    // Aggregate modules process every sample at once (their inputs are .collect()ed
    // in amp-proc.nf, so they already start only after their branch's per-sample
    // steps finish). Reserve the whole budget so they run alone with all threads;
    // each module passes ${task.cpus} to the tool's --nslots, i.e. nslots * maxForks.
    withName: 'MODULE_2_1_DADA2_PIPELINE|MODULE_2_2_2_VSEARCH_PIPELINE|MODULE_3_TAXA_ANNOT' {
        cpus = params.nslots * params.maxForks
    }

    withName: MODULE_3_TAXA_ANNOT {
        containerOptions = "--volume ${System.getenv('HOME')}/.amp-proc:${System.getenv('HOME')}/.amp-proc"
    }
}
