docker.enabled = true

params {
    help           = false
    input_dir      = './tests/data'
    reads_pattern  = "*_R{1,2}_001_redu.fastq.gz"
    output_dir     = './tests/output_nf'
    nslots         = 12
    full_output    = true
    method         = 'both'   // dada2 | vsearch | both
    skip_tax_annot = true
    maxForks       = 3

    // Primers (shared by MODULE_1_2 and MODULE_1_3)
    primer_fwd = "GTGYCAGCMGCCGCGGTAA"
    primer_rev = "CCGYCAATTYMTTTRAGTTT"

    // MODULE_1_1 — fastp quality check
    qc_min_length              = 50
    qualified_quality_phred    = 20
    unqualified_percent_limit  = 40
    disable_adapter_trimming   = 't'

    // MODULE_1_2 — primer check (before / after)
    subsample_size = 1000

    // MODULE_1_3 — cutadapt primer removal
    error_rate        = 0.1
    min_overlap       = 5
    min_length        = 50
    discard_untrimmed = 't'

    // MODULE_2_1 — DADA2 (ASV)
    trunc_r1          = 250
    trunc_r2          = 200
    dada2_min_overlap = 12
    bimeras_method    = 'consensus'

    // MODULE_2_2_1 — VSEARCH per-sample
    fastq_minovlen     = 5
    fastq_maxdiffs     = 2
    fastq_maxee        = 1.0
    min_size           = 1
    abskew             = 2.0
    vsearch_min_length = 50

    // MODULE_2_2_2 — VSEARCH OTU construction
    identity = 0.97

    // MODULE_3 — taxonomic annotation
    taxa_method = "NBC"
    evalue      = 1e-10
    min_identity = 97
    train_db    = "${System.getenv('HOME')}/.amp-proc/db/silva_nr_v138_train_seq.fa.gz"
    ref_db      = "${System.getenv('HOME')}/.amp-proc/db/silva_species_assignment_v138.fa.gz"
}

process {
    maxForks = params.maxForks

    withName: MODULE_3 {
        containerOptions = "--volume ${System.getenv('HOME')}/.amp-proc:${System.getenv('HOME')}/.amp-proc"
    }
}
